rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for wrappd stats
    match /wrappdStats/{document} {
      function signedInUserName() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.untappd_username;
      }

      function ownsWrappd() {
        return request.auth != null &&
          (
            resource.data.userId == request.auth.uid ||
            (
              resource.data.userName is string &&
              signedInUserName() == resource.data.userName
            )
          );
      }

      // Allow anyone to read wrappd stats
      allow read: if true;
      
      // Allow anyone to create new wrappd stats
      allow create: if 
        // Document must have required fields
        request.resource.data.stats is list &&
        request.resource.data.createdAt is string &&
        // Stats array must not be empty
        request.resource.data.stats.size() > 0;
      
      // Wrappds are immutable, but owners can remove their own shared links
      allow update: if false;
      allow delete: if ownsWrappd();
    }

    // Rules for leaderboard
    match /leaderboard/{uid} {
      // Any authenticated user can read the leaderboard
      allow read: if request.auth != null;

      // Authenticated users can only write their own leaderboard entry
      allow write: if request.auth != null && request.auth.uid == uid;

      match /comparisonMonths/{monthId} {
        // Any authenticated user can read comparison month summaries
        allow read: if request.auth != null;

        // Authenticated users can only write their own comparison summaries
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 
